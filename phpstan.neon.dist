includes:
    - phpstan-baseline.neon

parameters:
    level: 10
    paths:
        - src
        - tests
    excludePaths:
        - tests/ArchTest.php
    tmpDir: build/phpstan
    reportUnmatchedIgnoredErrors: true
    treatPhpDocTypesAsCertain: true
    parallel:
        maximumNumberOfProcesses: 1

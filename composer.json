{
    "name": "maxiviper117/laravel-paystack-sdk",
    "description": "Laravel Paystack SDK built with Saloon and a Laravel-first convenience layer.",
    "keywords": [
        "maxiviper117",
        "laravel",
        "paystack",
        "sdk"
    ],
    "homepage": "https://github.com/Maxiviper117/laravel-paystack-sdk",
    "license": "MIT",
    "authors": [
        {
            "name": "David",
            "email": "maxiviper117@users.noreply.github.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3|^8.4",
        "illuminate/contracts": "^11.0||^12.0",
        "saloonphp/laravel-plugin": "^4.0",
        "saloonphp/saloon": "^4.0",
        "spatie/laravel-data": "^4.21.0",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-webhook-client": "^3.5"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29.0",
        "nunomaduro/collision": "^8.9.3",
        "orchestra/testbench": "^10.9.0||^9.0.0",
        "pestphp/pest": "^4.4.6",
        "pestphp/pest-plugin-arch": "^4.0.2",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "2.4.1",
        "spatie/laravel-ray": "^1.43.7"
    },
    "autoload": {
        "psr-4": {
            "Maxiviper117\\Paystack\\": "src/",
            "Maxiviper117\\Paystack\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maxiviper117\\Paystack\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "@php tools/phpstan-analyse.php",
        "refactor": "vendor/bin/rector process",
        "refactor-dry": "vendor/bin/rector process --dry-run",
        "test": "vendor/bin/pest --parallel",
        "test-parallel": "vendor/bin/pest --parallel",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maxiviper117\\Paystack\\PaystackServiceProvider"
            ],
            "aliases": {
                "Paystack": "Maxiviper117\\Paystack\\Facades\\Paystack"
            }
        }
    },
    "prefer-stable": true
}
